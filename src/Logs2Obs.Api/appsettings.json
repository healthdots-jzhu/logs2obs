{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OpenTelemetry": {
    "ServiceName": "logs2obs-api",
    "ServiceVersion": "1.0.0"
  },
  "PayloadSize": {
    "MaxPayloadBytes": 10485760
  },
  "RateLimiter": {
    "IngestTokenLimit": 1000,
    "IngestTokensPerPeriod": 500,
    "QueryPermitLimit": 100
  },
  "ApiKey": {
    "HeaderName": "X-Api-Key",
    "CacheDurationSeconds": 300
  },
  "Auth": {
    "IdentityProviders": [
      {
        "Name": "Cognito-Internal",
        "Authority": "https://cognito-idp.{REPLACE_ME_REGION}.amazonaws.com/{REPLACE_ME_POOL_ID}",
        "Audiences": [ "{REPLACE_ME_CLIENT_ID_A}", "{REPLACE_ME_CLIENT_ID_B}" ],
        "ClaimsMappings": {
          "tenant_id": "custom:tenantId"
        }
      },
      {
        "Name": "EntraID",
        "Authority": "https://login.microsoftonline.com/{REPLACE_ME_TENANT_ID}/v2.0",
        "Audiences": [ "api://logs2obs" ],
        "ClaimsMappings": {
          "tenant_id": "extension_tenantId"
        }
      }
    ]
  }
}
