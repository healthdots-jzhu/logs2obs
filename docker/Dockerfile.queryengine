FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY ["src/Logs2Obs.QueryEngine/Logs2Obs.QueryEngine.csproj", "src/Logs2Obs.QueryEngine/"]
COPY ["src/Logs2Obs.Core/Logs2Obs.Core.csproj", "src/Logs2Obs.Core/"]
COPY ["src/Logs2Obs.Adapters.Local/Logs2Obs.Adapters.Local.csproj", "src/Logs2Obs.Adapters.Local/"]
RUN dotnet restore "src/Logs2Obs.QueryEngine/Logs2Obs.QueryEngine.csproj"
COPY . .
RUN dotnet publish "src/Logs2Obs.QueryEngine/Logs2Obs.QueryEngine.csproj" -c Release -o /app/publish

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS final
WORKDIR /app
EXPOSE 8083
COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "Logs2Obs.QueryEngine.dll"]
